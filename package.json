{
  "name": "smart-moves-app",
  "version": "1.0.0",
  "main": "App.tsx",
  "scripts": {
    "start": "npm run build && node server.js",
    "dev": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "proxy": "node proxy.js",
